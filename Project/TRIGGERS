There are two triggers:
1) Max 11 credits per faculty
CREATE OR REPLACE TRIGGER trg_max_credits
BEFORE INSERT OR UPDATE ON SECTION
FOR EACH ROW
DECLARE
  v_total NUMBER;
BEGIN
  IF :NEW.faculty_id IS NOT NULL THEN
    SELECT NVL(SUM(c.credits), 0)
    INTO v_total
    FROM SECTION s JOIN COURSE c ON s.course_id = c.course_id
    WHERE s.faculty_id = :NEW.faculty_id
      AND s.semester   = :NEW.semester
      AND s.section_id != NVL(:NEW.section_id, -1);

    SELECT v_total + c2.credits INTO v_total
    FROM COURSE c2 WHERE c2.course_id = :NEW.course_id;

    IF v_total > 11 THEN
      RAISE_APPLICATION_ERROR(-20001,
        'Credit limit exceeded: max 11 credits per faculty.');
    END IF;
  END IF;
END;
/
2) No same time slot clash 
CREATE OR REPLACE TRIGGER trg_no_slot_clash
BEFORE INSERT OR UPDATE ON SECTION
FOR EACH ROW
DECLARE
  v_count NUMBER;
BEGIN
  IF :NEW.faculty_id IS NOT NULL AND :NEW.slot_id IS NOT NULL THEN
    SELECT COUNT(*) INTO v_count
    FROM SECTION
    WHERE faculty_id = :NEW.faculty_id
      AND slot_id    = :NEW.slot_id
      AND semester   = :NEW.semester
      AND section_id != NVL(:NEW.section_id, -1);

    IF v_count > 0 THEN
      RAISE_APPLICATION_ERROR(-20002,
        'Time slot clash: faculty already assigned in this slot.');
    END IF;
  END IF;
END;
/
