-----Find duplicates by email addresses
SELECT email, COUNT(*) 
FROM FACULTY
GROUP BY email
HAVING COUNT(*) > 1;
-----DELETE Duplicate table
DELETE FROM FACULTY
WHERE ROWID NOT IN (
  SELECT MIN(ROWID)
  FROM FACULTY
  GROUP BY email
);

-------checking whether course data has any duplicates
SELECT course_code, COUNT(*)
FROM COURSE
GROUP BY course_code
HAVING COUNT(*) > 1;
